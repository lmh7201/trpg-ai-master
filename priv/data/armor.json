  "rules": [
    {
      "id": "armor-training",
      "title": "Armor Training",
      "titleKo": "갑옷 훈련",
      "description": "Anyone can don armor or hold a Shield, but only those with training can use them effectively, as explained below. A character's class and other features determine the character's armor training. A monster has training with any armor in its stat block.",
      "descriptionKo": "누구나 갑옷을 입거나 방패를 들 수 있지만, 아래에 설명된 대로 훈련받은 사람만이 효과적으로 사용할 수 있습니다. 캐릭터의 클래스와 기타 특징이 갑옷 훈련을 결정합니다. 몬스터는 스탯 블록에 있는 모든 갑옷에 대한 훈련을 받은 것으로 간주됩니다."
    },
    {
      "id": "light-medium-heavy-armor",
      "title": "Light, Medium, or Heavy Armor",
      "titleKo": "경갑, 평갑, 또는 중갑",
      "description": "If you wear Light, Medium, or Heavy armor and lack training with it, you have Disadvantage on any D20 Test that involves Strength or Dexterity, and you can't cast spells.",
      "descriptionKo": "경갑, 평갑, 또는 중갑을 입고 그것에 대한 훈련이 없다면, 근력이나 민첩이 관련된 모든 D20 판정에 불리를 받으며, 주문을 시전할 수 없습니다."
    },
    {
      "id": "shield-training",
      "title": "Shield",
      "titleKo": "방패",
      "description": "If you hold a Shield and lack training with it, you don't gain its Armor Class bonus.",
      "descriptionKo": "방패를 들고 있고 그것에 대한 훈련이 없다면, 방패의 방어 클래스 보너스를 받지 못합니다."
    },
    {
      "id": "ac-calculation",
      "title": "Armor Class Calculation",
      "titleKo": "방어 클래스 계산",
      "description": "Your base Armor Class equals 10 plus your Dexterity modifier. Armor provides a different way to calculate your Armor Class. Some class features and magic items can also change your Armor Class calculation. You can benefit from only one Armor Class calculation at a time. If two or more calculations are available to you, you choose which one to use.",
      "descriptionKo": "기본 방어 클래스는 10에 민첩 수정치를 더한 값입니다. 갑옷은 방어 클래스를 계산하는 다른 방법을 제공합니다. 일부 클래스 특성과 마법 아이템도 방어 클래스 계산을 변경할 수 있습니다. 한 번에 하나의 방어 클래스 계산만 받을 수 있습니다. 두 개 이상의 계산이 가능한 경우, 어떤 것을 사용할지 선택합니다."
    },
    {
      "id": "donning-doffing",
      "title": "Donning and Doffing Armor",
      "titleKo": "갑옷 착용 및 탈착",
      "description": "The time it takes to put on (don) or take off (doff) armor depends on the type of armor. If you have help, reduce the time by half. Don refers to putting armor on, while Doff refers to taking it off.",
      "descriptionKo": "갑옷을 입거나(착용) 벗는(탈착) 데 걸리는 시간은 갑옷 유형에 따라 다릅니다. 도움을 받으면 시간이 절반으로 줄어듭니다. 착용은 갑옷을 입는 것을, 탈착은 벗는 것을 의미합니다."
    },
    {
      "id": "strength-requirement",
      "title": "Strength Requirement",
      "titleKo": "근력 요구치",
      "description": "If armor has a Strength requirement, the armor reduces your Speed by 10 feet unless you meet the requirement.",
      "descriptionKo": "갑옷에 근력 요구치가 있는 경우, 해당 요구치를 충족하지 않으면 속도가 10피트 감소합니다."
    },
    {
      "id": "stealth-disadvantage",
      "title": "Stealth Disadvantage",
      "titleKo": "은신 불리",
      "description": "If the armor table shows \"Disadvantage\" in the Stealth column, the wearer has Disadvantage on Dexterity (Stealth) checks.",
      "descriptionKo": "갑옷 표의 은신 열에 \"불리\"가 표시되어 있으면, 착용자는 민첩(은신) 판정에 불리를 받습니다."
    }
  ]
}
